{
  "name": "1xx1",
  "version": "1.0.0",
  "description": "Decentralized, ad-free, open-source app ecosystem platform",
  "type": "module",
  "scripts": {
    "start":      "node --import=tsx/esm main.ts",
    "dev":        "X1_LOG_LEVEL=debug node --import=tsx/esm main.ts",
    "test":       "node --import=tsx/esm core/__tests__/run-all.ts",
    "perf":       "node --import=tsx/esm ops/performance/performance-cert.ts",
    "chaos":      "node --import=tsx/esm ops/reliability/chaos-tests.ts"
  },
  "engines": { "node": ">=20.0.0" },
  "keywords": ["decentralized", "p2p", "platform", "open-source"],
  "license": "MIT",
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
