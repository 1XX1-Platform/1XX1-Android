<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E1116">

    <!-- Tarayici toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#12161D"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical">

        <!-- Geri -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#5B8CFF"
            android:alpha="0.4"/>

        <!-- Ileri -->
        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_next"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#5B8CFF"
            android:alpha="0.4"/>

        <!-- URL bar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="#1F2530"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:layout_marginHorizontal="6dp">

            <!-- Node durum gostergesi -->
            <View
                android:id="@+id/statusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="6dp"/>

            <EditText
                android:id="@+id/urlBar"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:textColor="#E8EDF5"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:hint="1xx1://dashboard"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:singleLine="true"
                android:paddingVertical="0dp"/>

        </LinearLayout>

        <!-- Durum metni -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKTIF"
            android:textColor="#27C46A"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="4dp"/>

        <!-- Ana sayfa -->
        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_compass"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#5B8CFF"/>

        <!-- Yenile -->
        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_popup_sync"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#5B8CFF"/>

    </LinearLayout>

    <!-- Yükleme çubuğu -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:progressTint="#5B8CFF"
        android:visibility="gone"/>

    <!-- WebView -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
