<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E1116"
    android:padding="16dp">

    <!-- Baslik -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1XX1 NODE"
        android:textColor="#5B8CFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <!-- Durum paneli -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#12161D"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● OFFLINE"
            android:textColor="#FF4444"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvNodeId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Node: —"
            android:textColor="#6B7A90"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"/>

        <TextView
            android:id="@+id/tvPulse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pulse: #0"
            android:textColor="#5B8CFF"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"/>

        <TextView
            android:id="@+id/tvPeers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Peers: 0"
            android:textColor="#27C46A"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"/>
    </LinearLayout>

    <!-- Mod secimi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MOD"
        android:textColor="#6B7A90"
        android:textSize="11sp"
        android:paddingBottom="4dp"/>

    <RadioGroup
        android:id="@+id/rgMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/rbManual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Manuel"
            android:textColor="#E8EDF5"
            android:buttonTint="#5B8CFF"/>

        <RadioButton
            android:id="@+id/rbAuto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Otomatik"
            android:textColor="#E8EDF5"
            android:buttonTint="#5B8CFF"/>

        <RadioButton
            android:id="@+id/rbBackground"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Arka Plan"
            android:textColor="#E8EDF5"
            android:buttonTint="#5B8CFF"/>
    </RadioGroup>

    <!-- Butonlar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BASLAT"
            android:backgroundTint="#27C46A"
            android:textColor="#000000"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DURDUR"
            android:backgroundTint="#FF4444"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnBrowser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AC"
            android:backgroundTint="#5B8CFF"
            android:textColor="#FFFFFF"
            android:enabled="false"/>
    </LinearLayout>

    <!-- Log ekrani -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOG"
        android:textColor="#6B7A90"
        android:textSize="11sp"
        android:paddingBottom="4dp"/>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#12161D">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#27C46A"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

</LinearLayout>
